rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isAdmin() { return isSignedIn() && request.auth.token.email == 'pitop6988@gmail.com'; }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100))
        && (!('chips' in data) || data.chips is number)
        && (!('vipExp' in data) || data.vipExp is number)
        && (!('level' in data) || data.level is number)
        && (!('friends' in data) || data.friends is list)
        && (!('friendRequests' in data) || data.friendRequests is list);
    }

    function isValidClub(data) {
      return data.name is string && data.name.size() <= 64
        && data.ownerId is string && data.ownerId.size() <= 128
        && data.members is list && data.members.size() <= 60
        && (data.createdAt is int || data.createdAt is timestamp);
    }

    function isValidClubMessage(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.userName is string && data.userName.size() <= 64
        && data.text is string && data.text.size() <= 1000
        && (data.createdAt is int || data.createdAt is timestamp);
    }

    function isValidPartyRoom(data) {
      return data.ownerId is string && data.ownerId.size() <= 128
        && data.title is string && data.title.size() <= 100
        && (!('image' in data) || (data.image is string && data.image.size() <= 1000))
        && (!('viewers' in data) || data.viewers is number)
        && data.type in ['audio', 'pk']
        && (data.createdAt is int || data.createdAt is timestamp);
    }

    function isValidPartyRoomSeat(data) {
      return data.userId is string && data.userId.size() <= 128
        && (data.createdAt is int || data.createdAt is timestamp);
    }

    function isValidPartyRoomBanner(data) {
      return data.senderId is string && data.senderId.size() <= 128
        && data.senderName is string && data.senderName.size() <= 100
        && data.giftName is string && data.giftName.size() <= 100
        && data.giftPrice is number
        && (!('giftId' in data) || data.giftId is number || data.giftId is string)
        && (!('giftImage' in data) || data.giftImage is string)
        && (data.createdAt is int || data.createdAt is timestamp);
    }

    function isValidLuckyBag(data) {
      return data.senderId is string
        && data.total is number
        && data.qty is number
        && data.duration is number
        && data.condition in ['All', 'Fans', 'On mic']
        && data.type in ['Room', 'World']
        && (data.createdAt is int || data.createdAt is timestamp);
    }
    function isValidGame(data) {
      return data.status in ['waiting', 'active', 'finished']
        && data.players is list && data.players.size() <= 2
        && (data.createdAt is int || data.createdAt is timestamp);
    }

    // --- Rules ---

    // User Profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      
      allow update: if isOwner(userId) 
        || isAdmin()
        || (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['friendRequests']) && incoming().friendRequests.size() == existing().friendRequests.size() + 1 && request.auth.uid in incoming().friendRequests)
        || (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['friends']) && incoming().friends.size() == existing().friends.size() + 1 && request.auth.uid in incoming().friends);
        
      allow delete: if isAdmin();
    }

    // Config (Lobby Background, Sandbox Preset, etc.)
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Card Skins
    match /cardSkins/{skinId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Table Skins
    match /tableSkins/{tableId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Game Logos
    match /gameLogos/{logoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Club Logos
    match /clubLogos/{logoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Radio
    match /radioTracks/{trackId} {
      allow read: if true;
      allow write: if isAdmin();

      match /chunks/{chunkId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // Emojis/GIFs
    match /emojiItems/{emojiId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Live Gifts
    match /liveGifts/{giftId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Clubs
    match /clubs/{clubId} {
      function isClubMember() {
        return isSignedIn() && request.auth.uid in existing().members;
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidClub(incoming()) && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && isValidClub(incoming()) && (
        // Joining: members list grows, can be by request or owner
        (incoming().diff(existing()).affectedKeys().hasOnly(['members']) && (request.auth.uid in incoming().members || isClubMember())) ||
        // Leaving/Owner transfer: members can manage membership
        (incoming().diff(existing()).affectedKeys().hasOnly(['members', 'ownerId']) && isClubMember())
      );
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;

      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/clubs/$(clubId)).data.members
          && isValidClubMessage(incoming()) && incoming().userId == request.auth.uid;
      }
    }

    // Games
    match /games/{gameId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(gameId) && isValidGame(incoming())
        && incoming().players.size() >= 1 
        && incoming().players[0] == request.auth.uid
        && incoming().status == 'waiting';
      
      allow update: if isSignedIn() && isValidGame(incoming()) && (
        // Join Game Action
        (existing().status == 'waiting' && incoming().status == 'active' 
         && incoming().players.size() == 2 
         && incoming().players[0] == existing().players[0]
         && incoming().players[1] == request.auth.uid) ||
        
        // Gameplay Action
        (existing().status == 'active' && request.auth.uid in existing().players) ||
        
        // Finished Action
        (incoming().status == 'finished' && request.auth.uid in existing().players)
      );
      
      allow delete: if isSignedIn() && (existing().hostId == request.auth.uid || existing().players[0] == request.auth.uid);

      match /chat/{chatId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.players
          && incoming().userId == request.auth.uid && incoming().text is string && incoming().text.size() <= 1000;
      }
    }

    // Gifts
    match /gifts/{giftId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Party Rooms
    match /partyRooms/{roomId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(roomId) && isValidPartyRoom(incoming()) && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && isValidPartyRoom(incoming()) && (
        (incoming().ownerId == existing().ownerId)
      );
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;

      match /seats/{seatId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isValidId(seatId) && isValidPartyRoomSeat(incoming()) && incoming().userId == request.auth.uid;
        allow update: if isSignedIn() && existing().userId == request.auth.uid && isValidPartyRoomSeat(incoming());
        allow delete: if isSignedIn() && (existing().userId == request.auth.uid || get(/databases/$(database)/documents/partyRooms/$(roomId)).data.ownerId == request.auth.uid);
      }

      match /banners/{bannerId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isValidPartyRoomBanner(incoming()) && incoming().senderId == request.auth.uid;
      }

      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && incoming().userId == request.auth.uid && incoming().text is string;
      }

      match /superWinner/{docId} {
        allow read, write: if isSignedIn();
      }
      
      match /luckyBags/{bagId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }
  }
}
