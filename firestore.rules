rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isAdmin() { return isSignedIn() && request.auth.token.email == 'pitop6988@gmail.com'; }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100))
        && (!('chips' in data) || data.chips is number);
    }

    function isValidClub(data) {
      return data.name is string && data.name.size() <= 64
        && data.ownerId is string && data.ownerId.size() <= 128
        && data.members is list && data.members.size() <= 30
        && data.createdAt is int;
    }

    function isValidClubMessage(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.userName is string && data.userName.size() <= 64
        && data.text is string && data.text.size() <= 1000
        && data.createdAt is int;
    }

    function isValidGame(data) {
      return data.status in ['waiting', 'active', 'finished']
        && data.players is list && data.players.size() <= 2
        && data.createdAt is int;
    }

    // --- Rules ---

    // User Profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      
      allow update: if isOwner(userId) 
        || isAdmin()
        || (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['friendRequests']) && incoming().friendRequests.size() == existing().friendRequests.size() + 1 && request.auth.uid in incoming().friendRequests)
        || (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['friends']) && incoming().friends.size() == existing().friends.size() + 1 && request.auth.uid in incoming().friends);
        
      allow delete: if isAdmin();
    }

    // Config (Lobby Background, Sandbox Preset, etc.)
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Card Skins
    match /cardSkins/{skinId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Table Skins
    match /tableSkins/{tableId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Game Logos
    match /gameLogos/{logoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Club Logos
    match /clubLogos/{logoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Radio
    match /radioTracks/{trackId} {
      allow read: if true;
      allow write: if isAdmin();

      match /chunks/{chunkId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // Emojis/GIFs
    match /emojiItems/{emojiId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Clubs
    match /clubs/{clubId} {
      function isClubMember() {
        return isSignedIn() && request.auth.uid in existing().members;
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidClub(incoming()) && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && isValidClub(incoming()) && (
        // Joining: members list grows, can be by request or owner
        (incoming().diff(existing()).affectedKeys().hasOnly(['members']) && (request.auth.uid in incoming().members || isClubMember())) ||
        // Leaving/Owner transfer: members can manage membership
        (incoming().diff(existing()).affectedKeys().hasOnly(['members', 'ownerId']) && isClubMember())
      );
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;

      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/clubs/$(clubId)).data.members
          && isValidClubMessage(incoming()) && incoming().userId == request.auth.uid;
      }
    }

    // Games
    match /games/{gameId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(gameId) && isValidGame(incoming())
        && incoming().players.size() >= 1 
        && incoming().players[0] == request.auth.uid
        && incoming().status == 'waiting';
      
      allow update: if isSignedIn() && isValidGame(incoming()) && (
        // Join Game Action
        (existing().status == 'waiting' && incoming().status == 'active' 
         && incoming().players.size() == 2 
         && incoming().players[0] == existing().players[0]
         && incoming().players[1] == request.auth.uid) ||
        
        // Gameplay Action
        (existing().status == 'active' && request.auth.uid in existing().players) ||
        
        // Finished Action
        (incoming().status == 'finished' && request.auth.uid in existing().players)
      );
      
      allow delete: if isSignedIn() && (existing().hostId == request.auth.uid || existing().players[0] == request.auth.uid);

      match /chat/{chatId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.players
          && incoming().userId == request.auth.uid && incoming().text is string && incoming().text.size() <= 1000;
      }
    }
  }
}
