{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public profile and stats for a user",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "totalWins": { "type": "integer" },
        "chips": { "type": "integer" },
        "vipExp": { "type": "integer" },
        "level": { "type": "integer" },
        "shortId": { "type": "string" },
        "friendRequests": { "type": "array", "items": { "type": "string" } },
        "friends": { "type": "array", "items": { "type": "string" } },
        "ownedSkins": { "type": "array", "items": { "type": "string" } },
        "activeSkinId": { "type": "string" },
        "ownedEmojis": { "type": "array", "items": { "type": "string" } },
        "ownedTableSkins": { "type": "array", "items": { "type": "string" } },
        "activeTableSkinId": { "type": "string" }
      },
      "required": ["displayName", "chips"]
    },
    "RadioTrack": {
      "title": "Radio Track",
      "description": "Music track for the radio",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string" },
        "createdAt": { "type": "integer" }
      },
      "required": ["name", "url", "createdAt"]
    },
    "EmojiItem": {
      "title": "Emoji Item",
      "description": "Emoji or GIF available in the shop",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string" },
        "price": { "type": "integer" },
        "type": { "type": "string", "enum": ["emoji", "gif"] },
        "createdAt": { "type": "integer" }
      },
      "required": ["name", "url", "price", "type", "createdAt"]
    },
    "CardSkin": {
      "title": "Card Skin",
      "description": "Customizable card back skin available in the shop",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "imageUrl": { "type": "string" },
        "price": { "type": "integer" },
        "rarity": { "type": "string" }
      },
      "required": ["name", "imageUrl", "price", "rarity"]
    },
    "TableSkin": {
      "title": "Table Skin",
      "description": "Customizable poker table design available in the shop",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "imageUrl": { "type": "string" },
        "price": { "type": "integer" },
        "rarity": { "type": "string" }
      },
      "required": ["name", "imageUrl", "price", "rarity"]
    },
    "GameLogo": {
      "title": "Game Logo",
      "description": "Visual logo asset for a specific game arena",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "updatedAt": { "type": "integer" }
      },
      "required": ["url", "updatedAt"]
    },
    "Game": {
      "title": "Game Session",
      "description": "Represents a live game session between two players",
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["waiting", "active", "finished"] },
        "roomName": { "type": "string" },
        "password": { "type": "string" },
        "isPrivate": { "type": "boolean" },
        "players": { "type": "array", "items": { "type": "string" } },
        "playerNames": { "type": "object" },
        "turn": { "type": "string" },
        "deck": { "type": "array" },
        "hands": { "type": "object" },
        "pile": { "type": "array" },
        "scores": { "type": "object" },
        "winner": { "type": "string" },
        "createdAt": { "type": "integer" },
        "lastMoveAt": { "type": "integer" }
      },
      "required": ["status", "players", "createdAt", "roomName", "isPrivate"]
    },
    "Club": {
      "title": "Club/Syndicate",
      "description": "A group of players",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "logo": { "type": "string" },
        "ownerId": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "password": { "type": "string" },
        "isPrivate": { "type": "boolean" },
        "maxMembers": { "type": "integer" },
        "chipsPool": { "type": "integer" },
        "createdAt": { "type": "integer" }
      },
      "required": ["name", "ownerId", "members", "createdAt", "maxMembers"]
    },
    "PartyRoom": {
      "title": "Party Room",
      "description": "A live audio or PK party room",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "title": { "type": "string" },
        "image": { "type": "string" },
        "type": { "type": "string", "enum": ["audio", "pk"] },
        "viewers": { "type": "integer" },
        "createdAt": { "type": "integer" }
      },
      "required": ["ownerId", "title", "type", "createdAt"]
    },
    "PartyRoomSeat": {
      "title": "Party Room Seat",
      "description": "Represents one of the 16 mic seats in a party room",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "isMuted": { "type": "boolean" },
        "createdAt": { "type": "integer" }
      },
      "required": ["userId", "createdAt"]
    },
    "PartyRoomBanner": {
      "title": "Party Room Gift Banner",
      "description": "Announcement of a sent gift in the room",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderPhoto": { "type": "string" },
        "giftId": { "type": "integer" },
        "giftName": { "type": "string" },
        "giftImage": { "type": "string" },
        "giftPrice": { "type": "integer" },
        "createdAt": { "type": "integer" }
      },
      "required": ["senderId", "senderName", "giftId", "giftName", "giftPrice", "createdAt"]
    },
    "ClubMessage": {
      "title": "Club Message",
      "description": "Chat message within a club",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "integer" }
      },
      "required": ["userId", "userName", "text", "createdAt"]
    },
    "Config": {
      "title": "Configuration Settings",
      "description": "App configuration parameters such as current lobby background or sandbox templates",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "boardState": { "type": "string" },
        "updatedAt": { "type": "integer" }
      }
    }
  },
  "firestore": {
    "config/{configId}": {
      "schema": "Config",
      "description": "System-wide configs and presets"
    },
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "cardSkins/{skinId}": {
      "schema": "CardSkin",
      "description": "Available card skins in the shop"
    },
    "games/{gameId}": {
      "schema": "Game",
      "description": "Game sessions"
    },
    "partyRooms/{roomId}": {
      "schema": "PartyRoom",
      "description": "Active party rooms"
    },
    "partyRooms/{roomId}/seats/{seatId}": {
      "schema": "PartyRoomSeat",
      "description": "Mic seats (ids 1-16) within a party room"
    },
    "partyRooms/{roomId}/banners/{bannerId}": {
      "schema": "PartyRoomBanner",
      "description": "Gift announcements within a party room"
    },
    "clubs/{clubId}": {
      "schema": "Club",
      "description": "Club metadata"
    },
    "clubs/{clubId}/messages/{messageId}": {
      "schema": "ClubMessage",
      "description": "Club chat messages"
    },
    "radioTracks/{trackId}": {
      "schema": "RadioTrack",
      "description": "Radio music tracks"
    },
    "emojiItems/{emojiId}": {
      "schema": "EmojiItem",
      "description": "Shop emojis and GIFs"
    },
    "tableSkins/{tableId}": {
      "schema": "TableSkin",
      "description": "Available table layouts/skins in the shop"
    },
    "gameLogos/{logoId}": {
      "schema": "GameLogo",
      "description": "Logos for game arenas"
    }
  }
}
